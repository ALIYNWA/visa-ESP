# ============================================================
# VisaMonitor – Configuration (.env)
# Copier ce fichier en .env et remplir vos valeurs
# ============================================================

# --- Cible ---
TARGET_URL=https://www.blsspainvisa.com/algeria/bookappointment.php
VISA_CATEGORY=Spain
VISA_SUBCATEGORY=Short Stay

# --- Intervalles (secondes) ---
CHECK_INTERVAL_MIN=30
CHECK_INTERVAL_MAX=90
MAX_RETRIES=3

# --- Playwright ---
HEADLESS=true
BROWSER_TIMEOUT=30000

# --- Email (Gmail SMTP) ---
ENABLE_EMAIL=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=votre_app_password   # Mot de passe d'application Google
NOTIFY_EMAIL=destinataire@example.com

# --- Twilio SMS ---
ENABLE_SMS=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_FROM=+15551234567
NOTIFY_PHONE=+213XXXXXXXXX

# --- Twilio WhatsApp ---
ENABLE_WHATSAPP=false
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
NOTIFY_WHATSAPP=whatsapp:+213XXXXXXXXX

# --- Alertes ---
ALERT_COOLDOWN_MINUTES=15

# --- Serveur ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
