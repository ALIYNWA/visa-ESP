# TrialMatch — Configuration d'environnement
# Copier ce fichier en .env et adapter les valeurs

# ============================================================
# APPLICATION
# ============================================================
APP_ENV=production
APP_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
APP_DEBUG=false
CORS_ORIGINS=http://localhost:3000

# ============================================================
# BASE DE DONNÉES
# ============================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=trialmatch
POSTGRES_USER=trialmatch
POSTGRES_PASSWORD=changeme-strong-password-here
DATABASE_URL=postgresql+asyncpg://trialmatch:changeme-strong-password-here@db:5432/trialmatch

# ============================================================
# CHIFFREMENT (AES-256 via pgcrypto)
# Générer avec : openssl rand -base64 32
# ============================================================
ENCRYPTION_KEY=changeme-base64-encoded-32-byte-key
ENCRYPTION_SALT=changeme-base64-encoded-16-byte-salt
PBKDF2_ITERATIONS=600000

# ============================================================
# JWT
# Générer avec : openssl rand -hex 32
# ============================================================
JWT_SECRET_KEY=changeme-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# OLLAMA / LLM
# ============================================================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=meditron:70b
OLLAMA_TIMEOUT=300
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0

# ============================================================
# LDAP / ACTIVE DIRECTORY (optionnel)
# ============================================================
LDAP_ENABLED=false
LDAP_SERVER=ldap://your-ad-server:389
LDAP_BASE_DN=DC=hospital,DC=local
LDAP_BIND_DN=CN=svc-trialmatch,OU=Services,DC=hospital,DC=local
LDAP_BIND_PASSWORD=changeme
LDAP_USER_SEARCH_BASE=OU=Users,DC=hospital,DC=local

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_LOCKOUT_MINUTES=30

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/trialmatch.jsonl
