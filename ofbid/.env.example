# ============================================================
# RFP Intelligence Platform — Configuration
# Copier ce fichier en .env et remplir vos valeurs
# ============================================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modèle recommandé (Opus 4.5 pour la qualité maximale)
CLAUDE_MODEL=claude-opus-4-5-20251101

# --- Serveur ---
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# --- Limites ---
MAX_INPUT_CHARS=80000

# --- Scraping automatique ---
# Intervalle en secondes (21600 = 6h)
SCRAPE_INTERVAL_SECONDS=21600
